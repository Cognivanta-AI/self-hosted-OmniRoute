OMNIROUTE_IMAGE=diegosouzapw/omniroute:latest
OMNIROUTE_PORT=20128

# Public URL for the dashboard/API. In Coolify this is usually injected through
# SERVICE_URL_OMNIROUTE_20128 and does not need to be set manually.
NEXT_PUBLIC_BASE_URL=http://localhost:20128

# Change these values for any public deployment.
INITIAL_PASSWORD=change-this-password
JWT_SECRET=change-this-long-random-secret

# Runtime memory defaults.
OMNIROUTE_MEMORY_MB=512
NODE_OPTIONS=--max-old-space-size=512
